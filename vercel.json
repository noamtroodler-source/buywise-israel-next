{
  "version": 2,
  "buildCommand": "npm install && npm run build",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/**",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/~oauth/:path*",
      "destination": "https://buywise-israel-next.lovable.app/~oauth/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
